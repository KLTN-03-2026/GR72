DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=

PORT=8009
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001
JWT_SECRET=
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false
BCRYPT_SALT_ROUNDS=10
SEED_DEFAULT_PASSWORD=

# Bulk seed data (full DB load-test / demo)
# Set SEED_BULK=1 to enable large synchronized seed data generation.
SEED_BULK=1
# Number of generated end-user accounts
SEED_BULK_USERS=500
# Number of past days with meal logs per generated user
SEED_BULK_DAYS=30
# Meals generated per day (1..4: bua_sang, bua_trua, bua_toi, bua_phu)
SEED_BULK_MEALS_PER_DAY=4
# Meal plans generated per user
SEED_BULK_PLANS_PER_USER=6
# Target total food items in catalog after bulk seed
SEED_BULK_FOODS=2000
# Batch tag to identify generated records
SEED_BULK_TAG=bulk_sync_v1

# VNPay Configuration (https://sandbox.vnpayment.vn)
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPay return URL = BE endpoint sẽ redirect về FE payment-return page
VNPAY_RETURN_URL=http://localhost:3008/api/vnpay/callback
VNPAY_IPN_URL=http://localhost:3008/api/vnpay/callback/ipn
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction

# Client URL (để BE redirect về FE sau khi thanh toán)
CLIENT_URL=http://localhost:3001
# Phi dang ky Nutritionist (VND)
NUTRITIONIST_REGISTRATION_FEE=500000
# Gioi han dung luong tep chat (MB)
CHAT_ATTACHMENT_MAX_MB=25
# Gioi han body JSON cho request (vd gui file base64)
HTTP_JSON_BODY_LIMIT=40mb

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Nutrition App" <noreply@nutrition.app>

# LiveKit (WebRTC SFU) Configuration
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
